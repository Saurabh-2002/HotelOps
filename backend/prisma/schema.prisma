// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN // System admins only
  OWNER
  MANAGER
  FRONT_DESK
  HOUSEKEEPING
  RESTAURANT
  ACCOUNTANT
}

enum BookingStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum FolioStatus {
  OPEN
  SETTLED
}

enum RoomStatus {
  CLEAN
  DIRTY
  OUT_OF_ORDER
}

model Tenant {
  id                String   @id @default(uuid())
  name              String
  gstin             String?
  subscriptionTier  SubscriptionTier @default(BASIC)
  activeModules     String[] // e.g. ["RESTAURANT", "HOUSEKEEPING"]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  rooms             Room[]
  bookings          Booking[]
  guestRecords      GuestRecord[]
  folios            Folio[]
  menuItems         MenuItem[]
  posOrders         PosOrder[]
  propertySettings  PropertySettings?
  roomTypes         RoomType[]
}

model User {
  id             String   @id @default(uuid())
  tenantId       String?  // Nullable for Super-Admins
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  name           String
  email          String   @unique
  hashedPassword String
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

model Room {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  roomNumber  String
  roomTypeId  String?  // Made optional for migration backfill
  roomType    RoomType? @relation(fields: [roomTypeId], references: [id])
  legacyType  String?  // Temporarily store old roomType string for migration
  floor       String?
  baseRate    Decimal  @db.Decimal(10, 2)
  status      RoomStatus @default(CLEAN)
  maintenanceNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]

  @@unique([tenantId, roomNumber])
  @@index([tenantId])
}

model Booking {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id])
  checkInDate    DateTime @db.Date
  checkOutDate   DateTime @db.Date
  status         BookingStatus @default(RESERVED)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  guestRecords   GuestRecord[]
  folios         Folio[]
  posOrders      PosOrder[]

  @@index([tenantId])
}

model GuestRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  bookingId           String
  booking             Booking  @relation(fields: [bookingId], references: [id])
  fullName            String
  idType              String
  idNumber            String
  phone               String   @default("")
  address             String   @default("")
  email               String?
  encryptedFrroData   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
}

model Folio {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  totalAmount Decimal  @db.Decimal(10, 2)
  cgst        Decimal  @default(0) @db.Decimal(10, 2)
  sgst        Decimal  @default(0) @db.Decimal(10, 2)
  status      FolioStatus @default(OPEN)
  invoiceSnapshot Json?
  snapshotVersion Int?
  settledAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bookingId])

  @@index([tenantId])
}

enum PosOrderStatus {
  KOT_PRINTED
  SERVED
  BILLED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID_CASH
  POSTED_TO_ROOM
}

model MenuItem {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  itemCode        String?              // Human-readable code, e.g., "MC102"
  name            String
  category        String
  subcategory     String?              // e.g., "Chicken", "Paneer"
  price           Decimal  @db.Decimal(10, 2)  // Base/flat price (when no sizes)
  sizes           Json?                // e.g., ["Quarter","Half","Full"]
  sizePricing     Json?                // e.g., {"quarter":249,"half":449,"full":799}
  isAvailable     Boolean  @default(true)
  isArchived      Boolean  @default(false)
  imageUrl        String?
  isBestSeller    Boolean  @default(false)
  isChefSpecial   Boolean  @default(false)
  isRecommended   Boolean  @default(false)
  preparationTime Int?                 // Minutes
  rating          Decimal? @db.Decimal(2, 1)   // e.g., 4.8
  ratingCount     Int      @default(0)
  spiceLevels     Json?                // e.g., ["Mild","Medium","Hot"]
  extras          Json?                // e.g., [{"name":"Extra Cheese","price":30}]
  comboWith       Json?                // e.g., [{"itemCode":"MC105","name":"Naan","price":40}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      PosOrderItem[]

  @@unique([tenantId, itemCode])
  @@index([tenantId])
}

model PosOrder {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  bookingId   String?  // Optional: Link to a room/booking
  booking     Booking? @relation(fields: [bookingId], references: [id])
  status      PosOrderStatus @default(KOT_PRINTED)
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       PosOrderItem[]

  @@index([tenantId])
}

model PosOrderItem {
  id             String   @id @default(uuid())
  orderId        String
  order          PosOrder @relation(fields: [orderId], references: [id])
  menuItemId     String
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id])
  quantity       Int
  unitPrice      Decimal  @db.Decimal(10, 2)
  itemName       String?
  selectedSize   String?           // e.g., "Half"
  spiceLevel     String?           // e.g., "Medium"
  extras         Json?             // e.g., [{"name":"Extra Cheese","price":30}]
  comboItems     Json?             // e.g., [{"name":"Naan","price":40}]
  notes          String?
  createdAt      DateTime @default(now())

  @@index([orderId])
}

model PropertySettings {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  propertyName      String
  legalName         String?
  address           String?
  city              String?
  state             String?
  pinCode           String?
  country           String   @default("India")
  phone             String?
  email             String?
  gstin             String?
  checkInTime       String   @default("14:00")
  checkOutTime      String   @default("11:00")
  invoicePrefix     String   @default("INV-")
  timezone          String   @default("Asia/Kolkata")
  currency          String   @default("INR")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RoomType {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  name           String
  description    String?
  baseOccupancy  Int      @default(2)
  maxAdults      Int      @default(3)
  maxChildren    Int      @default(2)
  baseRate       Decimal  @db.Decimal(10, 2)
  extraAdultRate Decimal  @default(0) @db.Decimal(10, 2)
  extraChildRate Decimal  @default(0) @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rooms          Room[]

  @@unique([tenantId, name])
  @@index([tenantId])
}
